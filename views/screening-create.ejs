<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= screening ? 'Edit Screening' : 'Add Screening' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
  <style>
    .alert {
      padding: 15px;
      margin-bottom: 20px;
      border: 1px solid transparent;
      border-radius: 4px;
    }
    .alert-warning {
      color: #8a6d3b;
      background-color: #fcf8e3;
      border-color: #faebcc;
    }
    .alert-danger {
      color: #a94442;
      background-color: #f2dede;
      border-color: #ebccd1;
    }
  </style>
</head>
<body>
  <%- include('navbar') %>
  <%- include('sidebar') %>

  <div class="container">
    <h2><%= screening ? 'Edit Screening' : 'Add Screening' %></h2>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger" id="errorAlert">
        <strong>Error:</strong> <%= error %>
        <button type="button" onclick="document.getElementById('errorAlert').style.display='none';" style="float: right; cursor: pointer; border: none; background: none; font-size: 1.5em;">&times;</button>
      </div>
    <% } %>

    <form id="screeningForm" method="POST">
      <div class="form-group">
        <label>Select Movie</label>
        <select id="movieId" name="movieId" class="form-control" required onchange="updateMovieDuration()">
          <option value="">-- Select a Movie --</option>
          <% movies.forEach(movie => { %>
            <option value="<%= movie._id %>" 
              data-duration="<%= movie.duration %>"
              <%= screening && screening.movieId.toString() === movie._id.toString() ? 'selected' : '' %>>
              <%= movie.title %> (<%= movie.duration %> mins)
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Select Hall (Active Only)</label>
        <select id="hallId" name="hallId" class="form-control" required>
          <option value="">-- Select a Hall --</option>
          <% halls.forEach(hall => { %>
            <option value="<%= hall._id %>" <%= screening && screening.hallId.toString() === hall._id.toString() ? 'selected' : '' %>>
              <%= hall.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Date</label>
        <input type="date" id="date" name="date" class="form-control" required value="<%= screening && screening.date ? screening.date.split('T')[0] : '' %>" />
        <small style="color: #666;">Can only schedule from today onwards</small>
      </div>

      <div class="form-group">
        <label>Screening Time</label>
        <input type="time" id="screeningTime" name="screeningTime" class="form-control" required value="<%= screening ? screening.screeningTime : '' %>" />
      </div>

      <div class="form-group">
        <label>Estimated End Time</label>
        <input type="time" id="endTime" name="endTime" class="form-control" disabled value="<%= screening ? screening.endTime : '' %>" />
        <small style="color: #666;">Automatically calculated: Screening Time + Movie Duration + 30 mins (buffer)</small>
      </div>

      <% if (screening) { %>
        <div class="form-group">
          <label>Status</label>
          <select id="status" name="status" class="form-control">
            <option value="Available" <%= screening.status === 'Available' ? 'selected' : '' %>>Available</option>
            <option value="Playing" <%= screening.status === 'Playing' ? 'selected' : '' %>>Playing</option>
            <option value="Cancelled" <%= screening.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
        </div>
        <input type="hidden" id="screeningId" name="screeningId" value="<%= screening._id %>" />
      <% } %>
      <a href="/admin/screening-management" class="btn btn-secondary" style = "text-decoration: none;">Cancel</a>
      <button type="submit" class="btn btn-success"><%= screening ? 'Update Screening' : 'Add Screening' %></button>
    </form>
  </div>

  <script>
    // Set minimum date to today
    function setMinDate() {
      const today = new Date().toISOString().split('T')[0];
      document.getElementById('date').min = today;
    }

    function updateMovieDuration() {
      const movieSelect = document.getElementById('movieId');
      const selectedOption = movieSelect.options[movieSelect.selectedIndex];
      const duration = selectedOption.getAttribute('data-duration');
      const screeningTime = document.getElementById('screeningTime').value;
      
      if (!duration || !screeningTime) return;
      
      const [hours, minutes] = screeningTime.split(':').map(Number);
      const startMinutes = hours * 60 + minutes;
      const endMinutes = startMinutes + parseInt(duration) + 30;
      
      const endHours = Math.floor(endMinutes / 60);
      const endMins = endMinutes % 60;
      const endTimeStr = `${String(endHours).padStart(2, '0')}:${String(endMins).padStart(2, '0')}`;
      
      document.getElementById('endTime').value = endTimeStr;
    }

    async function submitScreening(e) {
      e.preventDefault();
      
      const form = document.getElementById('screeningForm');
      const screeningId = document.getElementById('screeningId')?.value;
      const url = screeningId 
        ? `/admin/screening-management/${screeningId}/edit` 
        : '/admin/screening-management/create';
      
      // Convert form data to URLSearchParams (sends as application/x-www-form-urlencoded)
      const formData = new FormData(form);
      const urlParams = new URLSearchParams(formData);
      
      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded'
          },
          body: urlParams.toString()
        });
        
        if (response.ok) {
          const result = await response.json();
          window.location.href = '/admin/screening-management';
        } else {
          const errorText = await response.text();
          alert('⚠️ ' + errorText);
        }
      } catch (err) {
        alert('❌ Error: ' + err.message);
      }
    }

    document.getElementById('screeningTime').addEventListener('change', updateMovieDuration);
    document.getElementById('movieId').addEventListener('change', updateMovieDuration);
    document.getElementById('screeningForm').addEventListener('submit', submitScreening);

    // Initialize on page load
    window.addEventListener('load', function() {
      setMinDate();
      updateMovieDuration();
    });
  </script>
</body>
</html>
