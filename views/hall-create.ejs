<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Create Hall</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
  <style>
 
  </style>
</head>
<body>
  <%- include('navbar') %>
  <%- include('sidebar') %>

  <div class="container">
    <h2><%= hall ? 'Edit Hall' : 'Create Cinema Hall' %></h2>
    <div id="form-section">
      <div class="form-group">
        <label>Hall Name</label>
        <input type="text" id="hallName" placeholder="e.g. Hall A" class="form-control" value="<%= hall ? hall.name : '' %>" />
      </div>
      <div class="form-group">
        <label>Hall Type</label>
        <select id="hallType" class="form-control">
          <option value="Standard" <%= hall && hall.type === 'Standard' ? 'selected' : '' %>>Standard</option>
          <option value="IMAX" <%= hall && hall.type === 'IMAX' ? 'selected' : '' %>>IMAX</option>
          <option value="Gold Class" <%= hall && hall.type === 'Gold Class' ? 'selected' : '' %>>Gold Class</option>
          <option value="Deluxe" <%= hall && hall.type === 'Deluxe' ? 'selected' : '' %>>Deluxe</option>
        </select>
      </div>
      <div class="form-group">
        <label>Rows</label>
        <input type="number" id="rows" min="1" max="26" class="form-control" value="<%= hall ? hall.rows : '' %>" />
      </div>
      <div class="form-group">
        <label>Columns</label>
        <input type="number" id="cols" min="1" max="30" class="form-control" value="<%= hall ? hall.columns : '' %>" />
      </div>
      <div class="form-group">
        <label>Number of Wheelchair Seats (placed at end of last row)</label>
        <input type="number" id="wheelchair" min="0" class="form-control" value="<%= hall ? (hall.wheelchair || 0) : '0' %>" />
      </div>
      <button onclick="generateDiagram()" class="btn btn-primary"><%= hall ? 'Update Diagram' : 'Generate Diagram' %></button>
    </div>

    <div id="diagram-section">
      <h4>Seat Layout Preview</h4>
      <p>Click a seat to toggle <strong>wheelchair</strong> or <strong>remove</strong> it. Right-click to restore.</p>

      <div class="legend" style="margin-bottom:12px;">
        <span style="background:#90e397"></span> Normal &nbsp;
        <span style="background:#60a5fa"></span> Wheelchair &nbsp;
        <span style="background:#374151; opacity:0.4"></span> Removed
      </div>

      <div class="screen">SCREEN</div>
      <div id="seat-grid"></div>

      <!-- Hidden form to submit to server -->
      <form method="POST" action="<%= hall ? '/admin/hall-management/' + hall._id + '/edit' : '/admin/hall-management/create' %>" id="confirmForm">
        <input type="hidden" name="name" id="f-name" />
        <input type="hidden" name="type" id="f-type" />
        <input type="hidden" name="rows" id="f-rows" />
        <input type="hidden" name="columns" id="f-cols" />
        <input type="hidden" name="seat" id="f-seats" />
        <input type="hidden" name="wheelchair" id="f-wheelchair" />
        <br/>
        <button type="button" onclick="goBack()" class="btn btn-secondary">Back</button>
        <button type="button" onclick="confirmHall()" class="btn btn-success">Confirm & Save Hall</button>
      </form>
    </div>
  </div>

  <script src="/sidebar-toggle.js"></script>
  <script src="/hall-create.js"></script>
  <script>
    existingSeats = <%= hall && hall.seat ? JSON.stringify(hall.seat) : '[]' %>;
  </script>
</body>
</html>