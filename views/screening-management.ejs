<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Best Cinema - Movie Management</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
</head>

<body>
  <%- include('navbar') %>
  <%- include('sidebar') %>

  <div class="container">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <h2 class = "management-title">Screening Management</h2>
      <a href="/admin/screening-management/create" class="btn btn-create-hall">+ Add Screening</a>
    </div>

    <div class="search-bar">
      <input type="text" id="screeningSearchInput" placeholder="Search by movie title or hall name..." class="form-control" style="max-width: 300px;">
    </div>

    <% if (screenings.length === 0) { %>
      <p>No Screenings added yet.</p>
    <% } else { %>
      <%
        // Separate upcoming and played screenings
        const now = new Date();
        const upcoming = [];
        const played = [];
        
        screenings.forEach(screening => {
          const screeningDate = new Date(screening.date);
          const [endHours, endMins] = screening.endTime.split(':').map(Number);
          screeningDate.setHours(endHours, endMins, 0, 0);
          
          if (screeningDate > now) {
            upcoming.push(screening);
          } else {
            played.push(screening);
          }
        });
      %>
      <h3 class="little-title">Upcoming Screenings</h3>
      <% if (upcoming.length === 0) { %>
        <p style="color: #666;">No upcoming screenings.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Movie</th>
              <th>Hall</th>
              <th>Date</th>
              <th>Time</th>
              <th>End Time</th>
              <th>Current Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% upcoming.forEach(screening => { %>
            <%
              const now = new Date();
              const screeningDate = new Date(screening.date);
              const [startHours, startMins] = screening.screeningTime.split(':').map(Number);
              const [endHours, endMins] = screening.endTime.split(':').map(Number);
              
              screeningDate.setHours(startHours, startMins, 0, 0);
              const endDateTime = new Date(screeningDate);
              endDateTime.setHours(endHours, endMins, 0, 0);
              
              const isPlaying = now >= screeningDate && now <= endDateTime;
              const displayStatus = isPlaying ? 'Playing' : screening.status;
            %>
            <tr>
              <td><%= screening.movieTitle %></td>
              <td><%= screening.hallName %></td>
              <td><%= screening.date ? screening.date.split('T')[0] : '' %></td>
              <td><%= screening.screeningTime %></td>
              <td><%= screening.endTime %></td>
              <td><span style="<%= isPlaying ? 'color: red; font-weight: bold;' : '' %>"><%= displayStatus %></span></td>
              <td>
                <form method="GET" action="/admin/screening-management/<%= screening._id %>/edit" style="display:inline">
                  <button class="btn btn-sm btn-edit">Edit</button>
                </form>
                <form method="POST" action="/admin/screening-management/<%= screening._id %>/delete" style="display:inline"
                  onsubmit="return confirm('Delete this screening?')">
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>

      <h3 class="little-title">Played Screenings</h3>
      <% if (played.length === 0) { %>
        <p style="color: #666;">No played screenings yet.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Movie</th>
              <th>Hall</th>
              <th>Date</th>
              <th>Time</th>
              <th>End Time</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% played.forEach(screening => { %>
            <tr style="background-color: #f5f5f5;">
              <td><%= screening.movieTitle %></td>
              <td><%= screening.hallName %></td>
              <td><%= screening.date ? screening.date.split('T')[0] : '' %></td>
              <td><%= screening.screeningTime %></td>
              <td><%= screening.endTime %></td>
              <td><span style="color: #999;">Played</span></td>
              <td>
                <form method="POST" action="/admin/screening-management/<%= screening._id %>/delete" style="display:inline"
                  onsubmit="return confirm('Delete this screening?')">
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    <% } %>
  </div>

  <script src="/sidebar-toggle.js"></script>
  <script>
    const searchInput = document.getElementById('screeningSearchInput');
    const upcomingRows = document.querySelectorAll('table tbody tr');

    searchInput.addEventListener('keyup', () => {
      const searchTerm = searchInput.value.toLowerCase();
      upcomingRows.forEach(row => {
        const movieCell = row.cells[0];
        const hallCell = row.cells[1];
        const movieTitle = movieCell ? movieCell.textContent.toLowerCase() : '';
        const hallName = hallCell ? hallCell.textContent.toLowerCase() : '';
        
        if (movieTitle.includes(searchTerm) || hallName.includes(searchTerm)) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });
  </script>
</body>
</html>