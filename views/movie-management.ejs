<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Best Cinema - Movie Management</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
</head>

<body>
  <%- include('navbar') %>
  <%- include('sidebar') %>

  <div class="container">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <h2 class="management-title">Movie Management</h2>
      <a href="/admin/movie-management/create" class="btn btn-create-hall">+ Add Film</a>
    </div>

    <div class="search-bar">
      <input type="text" id="movieSearchInput" placeholder="Search movies by title..." class="form-control" style="max-width: 300px;">
    </div>

    <% if (movies.length === 0) { %>
      <p>No Films added yet.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Poster</th>
            <th>Genre</th>
            <th>Duration (minutes)</th>
            <th>Age Rating</th>
            <th>Release Date</th>
            <th>Summary</th>
            <th>Rating (0-10)</th>
            <th>Price (S$)</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% movies.forEach(movie => { %>
          <tr>
            <td><%= movie.title %></td>
            <td><img src="<%= movie.poster %>" style="max-width: 80px; max-height: 120px; object-fit: cover;" alt="<%= movie.title %> poster" /></td>
            <td><%= Array.isArray(movie.genre) ? movie.genre.join(', ') : movie.genre %></td>
            <td><%= movie.duration %></td>
            <td><%= movie.ageRating %></td>
            <td><%= movie.releaseDate %></td>
            <td><%= movie.summary %></td>
            <td><%= movie.rating %></td>
            <td><%= movie.price %></td>
            <td>
              <form method="GET" action="/admin/movie-management/<%= movie._id %>/edit" style="display:inline">
                <button class="btn btn-sm btn-edit">Edit</button>
              </form>
              <form method="POST" action="/admin/movie-management/<%= movie._id %>/delete" style="display:inline"
                onsubmit="return confirm('Delete this Film?')">
                <button class="btn btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <script src="/sidebar-toggle.js"></script>
  <script>
    const searchInput = document.getElementById('movieSearchInput');
    const tableRows = document.querySelectorAll('table tbody tr');

    searchInput.addEventListener('keyup', () => {
      const searchTerm = searchInput.value.toLowerCase();
      tableRows.forEach(row => {
        const titleCell = row.cells[0];
        if (titleCell.textContent.toLowerCase().includes(searchTerm)) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });
  </script>
</body>
</html>
