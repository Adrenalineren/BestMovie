<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Best Cinema - Movie Management</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
</head>

<body>
  <%- include('navbar') %>
  <%- include('sidebar') %>

  <div class="container">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <h2 class="management-title">Movie Management</h2>
      <a href="/admin/movie-management/create" class="btn btn-create-hall">+ Add Film</a>
    </div>

    <% if (error) { %>
      <div style="background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; border-radius: 4px; padding: 12px 16px; margin-bottom: 20px;">
        <i class="bi bi-exclamation-circle"></i> <%= error %>
      </div>
    <% } %>

    <div class="search-bar">
      <input type="text" id="movieSearchInput" placeholder="Search movies by title..." class="form-control" style="max-width: 300px;">
    </div>

    <div class="filters-container">
      <div class="filter-age">
        <label for="ageFilter">Filter by Age Rating:</label>
        <select id="ageFilter" class="form-control">
          <option value="">All</option>
          <option value="G">G</option>
          <option value="PG">PG</option>
          <option value="PG-13">PG13</option>
          <option value="NC16">NC16</option>
          <option value="M18">M18</option>
          <option value="R21">R21</option>
        </select>
      </div>

      <div class="filter-genre">
        <label for="genreFilter">Filter by Genre:</label>
        <select id="genreFilter" class="form-control">
          <option value="">All</option>
          <option value="Drama">Drama</option>
          <option value="Romance">Romance</option>
          <option value="Comedy">Comedy</option>
          <option value="Sci-Fi">Sci-Fi</option>
          <option value="Action">Action</option>
          <option value="Horror">Horror</option>
          <option value="Thriller">Thriller</option>
          <option value="Documentary">Documentary</option>
          <option value="Autobiography">Autobiography</option>
          <option value="Coming of Age">Coming of Age</option>
          <option value="Sports">Sports</option>
        </select>
      </div>
    </div>

    <% if (movies.length === 0) { %>
      <p>No Films added yet.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Poster</th>
            <th>Genre</th>
            <th>Duration (minutes)</th>
            <th>Age Rating</th>
            <th>Release Date</th>
            <th>Summary</th>
            <th>Rating (0-10)</th>
            <th>Price (S$)</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% movies.forEach(movie => { %>
          <tr>
            <td><%= movie.title %></td>
            <td><img src="<%= movie.poster %>" style="max-width: 80px; max-height: 120px; object-fit: cover;" alt="<%= movie.title %> poster" /></td>
            <td><%= Array.isArray(movie.genre) ? movie.genre.join(', ') : movie.genre %></td>
            <td><%= movie.duration %></td>
            <td><%= movie.ageRating %></td>
            <td><%= movie.releaseDate %></td>
            <td><%= movie.summary %></td>
            <td><%= movie.rating %></td>
            <td><%= movie.price %></td>
            <td>
              <form method="GET" action="/admin/movie-management/<%= movie._id %>/edit" style="display:inline">
                <button class="btn btn-sm btn-edit">Edit</button>
              </form>
              <form method="POST" action="/admin/movie-management/<%= movie._id %>/delete" style="display:inline"
                onsubmit="return confirm('Delete this Film?')">
                <button class="btn btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <script src="/sidebar-toggle.js"></script>
  <script>
    const searchInput = document.getElementById('movieSearchInput');
    const ageFilter = document.getElementById('ageFilter');
    const genreFilter = document.getElementById('genreFilter');
    const tableRows = document.querySelectorAll('table tbody tr');

    function applyFilters() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedAge = ageFilter.value;
      const selectedGenre = genreFilter.value;

      tableRows.forEach(row => {
        const titleCell = row.cells[0];
        const genreCell = row.cells[2];
        const ageCell = row.cells[4];

        // Check search
        const matchesSearch = titleCell.textContent.toLowerCase().includes(searchTerm);
        
        // Check age filter
        const matchesAge = selectedAge === '' || ageCell.textContent.trim() === selectedAge;
        
        // Check genre filter (check if selected genre is in the comma-separated list)
        let matchesGenre = selectedGenre === '';
        if (selectedGenre !== '') {
          const genreList = genreCell.textContent.split(',').map(g => g.trim());
          matchesGenre = genreList.includes(selectedGenre);
        }

        // Show row only if all conditions are met
        if (matchesSearch && matchesAge && matchesGenre) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    }

    searchInput.addEventListener('keyup', applyFilters);
    ageFilter.addEventListener('change', applyFilters);
    genreFilter.addEventListener('change', applyFilters);
  </script>
</body>
</html>
