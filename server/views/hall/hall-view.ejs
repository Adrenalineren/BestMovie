<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>View Hall - <%= hall.name %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
  <style>
    .hall-info {
      background: #f5f5f5;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 25px;
    }
    .hall-info-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
    }
    .info-item {
      display: flex;
      flex-direction: column;
    }
    .info-label {
      font-weight: bold;
      color: #666;
      font-size: 0.9em;
      margin-bottom: 5px;
    }
    .info-value {
      color: #333;
      font-size: 1.1em;
    }
  </style>
</head>
<body>
  <%- include('../navbar') %>
  <%- include('../sidebar') %>

  <div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h2 class="management-title"><%= hall.name %> - Hall Layout</h2>
      <a href="/admin/hall/hall-management" class="btn btn-backtohalls">Back to Halls</a>
    </div>

    <div id="diagram-section" style="display: flex;">
      <h4>Seat Layout Preview</h4>
      
      <div class="legend" style="margin-bottom: 12px;">
        <span style="background: #90e397;"></span> Normal &nbsp;
        <span style="background: #60a5fa;"></span> Wheelchair &nbsp;
        <span style="background: #374151; opacity: 0.4;"></span> Removed
      </div>

      <div class="screen">SCREEN</div>
      <div id="seat-grid"></div>
    </div>

  </div>

  <script src="/sidebar-toggle.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const hallData = <%- JSON.stringify(hall) %>;
      console.log('Hall Data:', hallData);
      generateViewDiagram(hallData);
    });

    function generateViewDiagram(hall) {
      console.log('Generating diagram for:', hall.name);
      console.log('Rows:', hall.rows, 'Columns:', hall.columns);
      
      const rows = parseInt(hall.rows);
      const cols = parseInt(hall.columns);
      const seatData = hall.seat || [];
      const grid = document.getElementById('seat-grid');
      grid.innerHTML = '';

      // Create a map of seat types
      const seatMap = {};
      seatData.forEach(seat => {
        seatMap[`${seat.row}${seat.col}`] = seat.type;
      });

      console.log('Seat Map:', seatMap);
      console.log('Creating grid with rows:', rows, 'cols:', cols);

      for (let r = 0; r < rows; r++) {
        const rowLabel = String.fromCharCode(65 + r);
        const rowDiv = document.createElement('div');
        rowDiv.className = 'seat-row';

        const label = document.createElement('div');
        label.className = 'row-label';
        label.textContent = rowLabel;
        rowDiv.appendChild(label);

        for (let c = 0; c < cols; c++) {
          const seatKey = `${rowLabel}${c + 1}`;
          const isWheelchair = (r === rows - 1) && (c >= cols - (hall.wheelchair || 0));
          
          // Check if seat is deleted
          const seatType = seatMap[seatKey];
          const type = seatType === 'deleted' ? 'deleted' : (seatType === 'wheelchair' || isWheelchair ? 'wheelchair' : 'normal');

          const seat = document.createElement('div');
          seat.className = `seat ${type}`;
          seat.style.cursor = 'default';
          seat.style.pointerEvents = 'none';
          seat.title = `${rowLabel}${c + 1}`;
          seat.textContent = c + 1;

          rowDiv.appendChild(seat);
        }
        grid.appendChild(rowDiv);
      }
      
      console.log('Diagram generation complete');
    }
  </script>
</body>
</html>
