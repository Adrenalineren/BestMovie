<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Best Cinema - Hall Management</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
  <style>
    .admin-toast {
      position: fixed;
      top: 18px;
      right: 18px;
      z-index: 1200;
      max-width: 420px;
      padding: 14px 16px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      text-align: left;
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.25);
      animation: slideIn 0.3s ease-out;
    }

    @keyframes slideIn {
      from {
        transform: translateX(420px);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    .admin-toast-success {
      background: #1b5e20;
      color: #c8e6c9;
      border: 1px solid #4caf50;
    }

    .admin-toast-error {
      background: #3b1010;
      color: #ffd6d6;
      border: 1px solid #c55353;
    }
  </style>
</head>

<body>
  <%- include('../navbar') %>
  <%- include('../sidebar') %>

  <div class="container">
    <% if (success) { %>
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          showAdminToast('<%= success.replace(/'/g, "\\'") %>', 'success');
        });
      </script>
    <% } %>
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <h2 class = "management-title">Hall Management</h2>
      <a href="/admin/hall/hall-management/create" class="btn btn-create-hall">+ Create Hall</a>
    </div>
    <div class="hall-stats">
      <div class="hall-stat-card hall-stat-active">
        <div class="hall-stat-number"><%= halls.filter(h => h.status === 'active').length %></div>
        <div class="hall-stat-label">Active Halls</div>
      </div>
      <div class="hall-stat-card hall-stat-maintenance">
        <div class="hall-stat-number"><%= halls.filter(h => h.status !== 'active').length %></div>
        <div class="hall-stat-label">Under Maintenance</div>
      </div>
      <div class="hall-stat-card hall-stat-total">
        <div class="hall-stat-number"><%= halls.length %></div>
        <div class="hall-stat-label">Total Halls</div>
      </div>
    </div>

    <% if (halls.length === 0) { %>
      <p>No halls created yet.</p>
    <% } else { %>
      <%
        const hallTypes = ['Standard', 'Deluxe', 'Gold Class', 'IMAX'];
      %>
      <% hallTypes.forEach(type => { %>
        <% const filtered = halls.filter(h => h.type === type); %>
        <% if (filtered.length > 0) { %>
          <h3 class="little-title"><%= type %></h3>
          <table class="table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Rows</th>
                <th>Columns</th>
                <th>Seats</th>
                <th>Wheelchair</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% filtered.forEach(hall => { %>
              <tr>
                <td><%= hall.name %></td>
                <td><%= hall.rows %></td>
                <td><%= hall.columns %></td>
                <td><%= hall.seat && hall.seat.length > 0 ? hall.seat.filter(s => s.type === 'normal').length : ((hall.rows * hall.columns) - (hall.wheelchair || 0)) %></td>
                <td><%= hall.seat && hall.seat.length > 0 ? hall.seat.filter(s => s.type === 'wheelchair').length : (hall.wheelchair || 0) %></td>
                <td>
                  <span class="badge <%= hall.status === 'active' ? 'badge-success' : 'badge-danger' %>">
                    <%= hall.status === 'active' ? 'Active' : 'Under Maintenance' %>
                  </span>
                </td>
                <td>
                  <button class="btn btn-sm btn-warning" onclick="toggleHallStatus('<%= hall._id %>', '<%= hall.status %>', '<%= hall.name %>')">
                    <%= hall.status === 'active' ? 'Set Maintenance' : 'Set Active' %>
                  </button>
                  <form method="GET" action="/admin/hall/hall-management/<%= hall._id %>/edit" style="display:inline">
                    <button class="btn btn-sm btn-edit">Edit</button>
                  </form>
                  <form method="POST" action="/admin/hall/hall-management/<%= hall._id %>/delete" style="display:inline"
                    onsubmit="return confirm('Delete this hall?')">
                    <button class="btn btn-sm btn-danger">Delete</button>
                  </form>
                  <a href="/admin/hall/hall-management/<%= hall._id %>/view" class="btn btn-sm btn-viewhall">View Hall</a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      <% }) %>
    <% } %>
  </div>

  <!-- Hidden form to submit status change -->
  <form id="statusForm" method="POST" style="display: none;"></form>

  <script src="/sidebar-toggle.js"></script>
  <script>
    let pendingStatusChange = null;

    async function toggleHallStatus(hallId, currentStatus, hallName) {
      if (currentStatus === 'active') {
        const confirmed = confirm(
          `Set ${hallName} to maintenance? All upcoming screenings in this hall will be cancelled and affected customers will see a cancellation notice in My Tickets.`
        );

        if (!confirmed) {
          return;
        }
      }

      submitStatusChange(hallId);
    }

    function submitStatusChange(hallId) {
      const form = document.getElementById('statusForm');
      form.method = 'POST';
      form.action = `/admin/hall/hall-management/${hallId}/status`;
      form.submit();
    }

    function showAdminToast(message, type = 'success') {
      const toast = document.createElement('div');
      toast.className = `admin-toast admin-toast-${type}`;
      toast.setAttribute('role', 'status');
      toast.setAttribute('aria-live', 'polite');
      
      const icon = type === 'success' ? '✓' : '✕';
      toast.innerHTML = `${icon} ${message}`;
      
      document.body.appendChild(toast);
      
      setTimeout(() => {
        toast.style.animation = 'slideIn 0.3s ease-out reverse';
        setTimeout(() => toast.remove(), 300);
      }, 4000);
    }
  </script>
</body>
</html>
