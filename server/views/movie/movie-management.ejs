<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Best Cinema - Movie Management</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
</head>

<body>
  <%- include('../navbar') %>
  <%- include('../sidebar') %>

  <div class="container">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <h2 class="management-title">Movie Management</h2>
      <a href="/admin/movie/movie-management/create" class="btn btn-create-hall">+ Add Film</a>
    </div>

    <% if (error) { %>
      <div style="background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; border-radius: 4px; padding: 12px 16px; margin-bottom: 20px;">
        <i class="bi bi-exclamation-circle"></i> <%= error %>
      </div>
    <% } %>
    <% if (success) { %>
       <div style="background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; border-radius: 4px; padding: 12px 16px; margin-bottom: 20px;">
        <i class="bi bi-check-circle"></i> 
    <%= success %>
  </div>
  <% } %>
    <div class="search-bar">
      <input type="text" id="movieSearchInput" placeholder="Search movies by title..." class="form-control" style="max-width: 300px;">
    </div>

    <div class="filters-container">
      <div class="filter-age">
        <label for="ageFilter">Filter by Age Rating:</label>
        <select id="ageFilter" class="form-control">
          <option value="">All</option>
          <option value="G">G</option>
          <option value="PG">PG</option>
          <option value="PG-13">PG13</option>
          <option value="NC16">NC16</option>
          <option value="M18">M18</option>
          <option value="R21">R21</option>
        </select>
      </div>

      <div class="filter-genre">
        <label for="genreFilter">Filter by Genre:</label>
        <select id="genreFilter" class="form-control">
          <option value="">All</option>
          <option value="Drama">Drama</option>
          <option value="Romance">Romance</option>
          <option value="Fantasy">Fantasy</option>
          <option value="Comedy">Comedy</option>
          <option value="Sci-Fi">Sci-Fi</option>
          <option value="Action">Action</option>
          <option value="Horror">Horror</option>
          <option value="Thriller">Thriller</option>
          <option value="Documentary">Documentary</option>
          <option value="Autobiography">Autobiography</option>
          <option value="Coming of Age">Coming of Age</option>
          <option value="Sports">Sports</option>
        </select>
      </div>
    </div>

    <% if (movies.length === 0) { %>
      <p>No Films added yet.</p>
    <% } else { %>
      <div class="playing-movies-grid" id="moviesContainer">
        <% movies.forEach(movie => { %>
        <div class="movie-card" data-title="<%= movie.title.toLowerCase() %>" data-genre="<%= Array.isArray(movie.genre) ? movie.genre.join(',').toLowerCase() : movie.genre.toLowerCase() %>" data-age="<%= movie.ageRating %>">
          <img src="<%= movie.poster %>" alt="<%= movie.title %> poster" class="movie-poster" />
          <div class="movie-info">
            <div class="movie-title"><%= movie.title %></div>
            <div class="movie-details">
              <div class="detail-row">
                <span class="detail-label">Genre:&nbsp;</span>
                <span class="detail-value"><%= Array.isArray(movie.genre) ? movie.genre.join(', ') : movie.genre %></span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Duration:&nbsp;</span>
                <span class="detail-value"><%= movie.duration %> min</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Rating:&nbsp;</span>
                <span class="detail-value"><%= movie.ageRating %></span>
              </div>
              <div class="movie-card-buttons">
                <a href="/admin/movie/movie-management/<%= movie._id %>/view" class="btn btn-sm btn-view" style="text-decoration: none;">Details</a>
                <form method="GET" action="/admin/movie/movie-management/<%= movie._id %>/edit" style="flex: 1; min-width: 60px;">
                  <button class="btn btn-sm btn-edit" style="width: 100%;">Edit</button>
                </form>
                <form method="POST" action="/admin/movie/movie-management/<%= movie._id %>/delete" style="flex: 1; min-width: 60px;"
                  onsubmit="return confirm('Delete this Film?')">
                  <button class="btn btn-sm btn-danger" style="width: 100%;">Delete</button>
                </form>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <script src="/sidebar-toggle.js"></script>
  <script>
    // Filter functions
    const searchInput = document.getElementById('movieSearchInput');
    const ageFilter = document.getElementById('ageFilter');
    const genreFilter = document.getElementById('genreFilter');
    const movieCards = document.querySelectorAll('.movie-card');

    function applyFilters() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedAge = ageFilter.value;
      const selectedGenre = genreFilter.value;

      movieCards.forEach(card => {
        const title = card.dataset.title;
        const genres = card.dataset.genre.split(',').map(g => g.trim());
        const age = card.dataset.age;

        // Check search
        const matchesSearch = title.includes(searchTerm);
        
        // Check age filter
        const matchesAge = selectedAge === '' || age === selectedAge;
        
        // Check genre filter
        const matchesGenre = selectedGenre === '' || genres.includes(selectedGenre.toLowerCase());

        // Show card only if all conditions are met
        if (matchesSearch && matchesAge && matchesGenre) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    }

    searchInput.addEventListener('keyup', applyFilters);
    ageFilter.addEventListener('change', applyFilters);
    genreFilter.addEventListener('change', applyFilters);
  </script>
</body>
</html>
