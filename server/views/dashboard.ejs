<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CineVillage - Dashboard</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
</head>
<body>
  <%- include('navbar') %>
  <%- include('sidebar') %>

<div class="dashboard">
  <div class="container-dashboard">
    <h2 style="margin-bottom: 20px;">Management Dashboard</h2>
    
    <div class="stats-summary" id="statsSummary">
      <div class="stat-card">
        <div class="stat-label">Today's Revenue</div>
        <div class="stat-value">-</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Today's Tickets Sold</div>
        <div class="stat-value">-</div>
      </div>
    </div>

    <div class="dashboard-wrapper">
      <div class="dashboard-left-panel">
        <div class="quick-actions-panel">
          <div class="panel-title">Quick Actions</div>
          <a href="/admin/bookings/bookings-management" class="action-link">
            <i class="bi bi-ticket-perforated"></i> Manage Bookings
          </a>
          <a href="/admin/hall/hall-management" class="action-link">
            <i class="bi bi-building-fill-add"></i> Manage Halls
          </a>
          <a href="/admin/movie/movie-management" class="action-link">
            <i class="bi bi-film"></i> Manage Movies
          </a>
          <a href="/admin/screening/screening-management" class="action-link">
            <i class="bi bi-calendar-event"></i> Manage Screenings
          </a>
        </div>
        <div class="upcoming-panel">
          <div class="panel-title">Upcoming — Today & Next 5 Days (<%= upcomingScreeningsCount %>)</div>
          <% if (upcomingScreenings && upcomingScreenings.length > 0) { %>
            <div class="upcoming-list">
              <% upcomingScreenings.forEach(screening => { %>
                <a href="/admin/screening/screening-management/<%= screening._id %>/edit" style="text-decoration: none; color: inherit;">
                  <div class="upcoming-list-item" style="cursor: pointer;">
                    <div class="upcoming-item-left">
                       <img src="<%= screening.poster %>" alt="<%= screening.movieTitle %>" class="upcoming-poster" onerror="this.src='/placeholder.jpg'" />
                      <div class="movie-name"><%= screening.movieTitle %></div>
                      <div class="movie-time"><%= screening.screeningTime %> &bull; <%= screening.hallName %></div>
                    </div>
                    <div class="movie-date"><%= screening.date %></div>
                  </div>
                </a>
              <% }); %>
            </div>
          <% } else { %>
            <div class="no-content">
              <i class="bi bi-calendar-plus"></i>
              <p>No upcoming screenings</p>
            </div>
          <% } %>
        </div>
        <div class="upcoming-panel">
          <div class="panel-title">Available Halls (<%= availableHallsCount %>)</div>
          <% if (availableHalls && availableHalls.length > 0) { %>
            <div class="upcoming-list">
              <% availableHalls.forEach(hall => { %>
                <div class="upcoming-list-item">
                  <div class="upcoming-item-left">
                    <div class="movie-name"><%= hall.name %></div>
                    <div class="movie-time"><%= hall.rows * hall.columns %> seats</div>
                  </div>
                  <div class="movie-date"><%= hall.type %></div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="no-content">
              <i class="bi bi-building"></i>
              <p>No available halls</p>
            </div>
          <% } %>
        </div>
      </div>


      <div class="dashboard-main">
        <div class="playing-section">
          <div class="section-title">Total Active Movies (<%= playingMoviesCount %>)</div>
          <% if (playingMovies && playingMovies.length > 0) { %>
            <div class="playing-movies-grid">
              <% playingMovies.forEach(screening => { %>
                <div class="movie-card">
                  <img src="<%= screening.poster %>" alt="<%= screening.movieTitle %>" class="movie-poster" onerror="this.src='/placeholder.jpg'" />
                  <div class="movie-info">
                    <div class="movie-title"><%= screening.movieTitle %></div>
                    <div class="movie-details">
                      <div class="detail-row">
                        <span class="detail-label">Hall:</span>
                        <span class="detail-value"><%= screening.hallName %></span>
                      </div>
                      <div class="detail-row">
                        <span class="detail-label">Start:</span>
                        <span class="detail-value"><%= screening.screeningTime %></span>
                      </div>
                      <div class="detail-row">
                        <span class="detail-label">End:</span>
                        <span class="detail-value"><%= screening.endTime %></span>
                      </div>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="no-content">
              <i class="bi bi-film"></i>
              <p>No movies currently playing</p>
            </div>
          <% } %>
        </div>
        <div class="upcoming-today-section">
          <div class="section-title">Coming up (<%= upcomingTodayScreeningsCount %>)</div>

          <% if (upcomingTodayScreenings && upcomingTodayScreenings.length > 0) { %>
            <div class="upcoming-today-list">
              <% upcomingTodayScreenings.forEach(screening => { %>
                <a href="/admin/screening/screening-management/<%= screening._id %>/edit" style="text-decoration: none; color: inherit;">
                  <div class="upcoming-today-item" style="cursor: pointer;">
                    <img src="<%= screening.poster %>" alt="<%= screening.movieTitle %>" class="upcoming-poster" onerror="this.src='/placeholder.jpg'" />
                    <div class="upcoming-today-info">
                      <div class="upcoming-today-title"><%= screening.movieTitle %></div>
                      <div class="upcoming-today-time"><i class="bi bi-clock"></i> <%= screening.screeningTime %></div>
                      <div class="upcoming-today-hall"><i class="bi bi-building"></i> <%= screening.hallName %></div>
                    </div>
                  </div>
                </a>
              <% }); %>
            </div>
          <% } else { %>
            <div class="no-content">
              <i class="bi bi-hourglass-end"></i>
              <p>No upcoming screenings Today</p>
            </div>
          <% } %>
        </div>

        <!-- Screenings Today with dropdown -->
        <div class="screenings-today-section">
          <div class="section-title-row">
            <div class="section-title">Screenings Today (<%= todayScreeningsCount %>)</div>
            <% if (todayScreenings && todayScreenings.length > 3) { %>
              <button class="show-more-btn" id="todayToggleBtn" onclick="toggleTodayScreenings()">Show All</button>
            <% } %>
          </div>

          <% if (todayScreenings && todayScreenings.length > 0) { %>
            <div class="today-screenings-list" id="todayScreeningsList">
              <% todayScreenings.forEach((screening, index) => { %>
                <div class="today-screening-item <%= index >= 3 ? 'hidden-item' : '' %>">
                  <img src="<%= screening.poster %>" alt="<%= screening.movieTitle %>" class="today-poster" onerror="this.src='/placeholder.jpg'" />
                  <div class="today-info">
                    <div class="today-title"><%= screening.movieTitle %></div>
                    <div class="today-meta"><i class="bi bi-clock"></i> <%= screening.screeningTime %></div>
                    <div class="today-meta"><i class="bi bi-building"></i> <%= screening.hallName %></div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="no-content">
              <i class="bi bi-calendar-x"></i>
              <p>No screenings scheduled for today</p>
            </div>
          <% } %>
        </div>
        <div class = "Leaving soon">
          <div class="section-title">Leaving Soon (<%= leavingSoonMoviesCount %>)</div>
          <% if (leavingSoonMovies && leavingSoonMovies.length > 0) { %>
            <div class="leaving-soon-list">
              <% leavingSoonMovies.forEach(movie => { %>
                <div class="today-screening-item">
                  <img src="<%= movie.poster %>" alt="<%= movie.title %>" class="today-poster" onerror="this.src='/placeholder.jpg'" />
                  <div class="leaving-soon-info">
                    <div class="leaving-soon-title"><%= movie.title %></div>
                    <div class="leaving-soon-meta"><i class="bi bi-calendar-x"></i> Leaving on <%= movie.leavingCinema ? movie.leavingCinema.split('T')[0] : 'N/A' %></div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="no-content">
              <i class="bi bi-calendar-check"></i>
              <p>No movies leaving soon</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

  <script src="/sidebar-toggle.js"></script>
  <script>
    let todayExpanded = false;

    function toggleTodayScreenings() {
      const hiddenItems = document.querySelectorAll('.hidden-item');
      const btn = document.getElementById('todayToggleBtn');
      todayExpanded = !todayExpanded;
      hiddenItems.forEach(item => {
        item.style.display = todayExpanded ? 'flex' : 'none';
      });
      btn.textContent = todayExpanded ? 'Show Less' : 'Show All';
    }

    // Load dashboard stats
    async function loadDashboardStats() {
      try {
        const statsResponse = await fetch('/api/admin/dashboard-stats');
        const statsData = await statsResponse.json();

        if (statsData.success) {
          const stats = statsData.stats;
          const summaryHTML = `
            <div class="stat-card">
              <div class="stat-label">Today's Revenue</div>
              <div class="stat-value">S$${parseFloat(stats.todayRevenue).toFixed(2)}</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Today's Tickets Sold</div>
              <div class="stat-value">${stats.todayTickets}</div>
            </div>
          `;
          document.getElementById('statsSummary').innerHTML = summaryHTML;
        }
      } catch (error) {
        console.error('Error loading dashboard stats:', error);
      }
    }

    // Initial load
    loadDashboardStats();

    // Auto-refresh every 10 seconds
    window.setInterval(loadDashboardStats, 10000);
  </script>
</body>
</html>
