<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Best Cinema - Movie Management</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
</head>

<body>
  <%- include('../navbar') %>
  <%- include('../sidebar') %>

  <% if (success) { %>
       <div style="background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; border-radius: 4px; padding: 12px 16px; margin-bottom: 20px;">
        <i class="bi bi-check-circle"></i> 
    <%= success %>
  </div>
  <% } %>
  <div class="container">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <h2 class = "management-title">Screening Management</h2>
      <a href="/admin/screening/screening-management/create" class="btn btn-create-hall">+ Add Screening</a>
    </div>

    <div class="search-bar">
      <input type="text" id="screeningSearchInput" placeholder="Search by movie title or hall name..." class="form-control" style="max-width: 300px;">
    </div>

    <% if (screenings.length === 0) { %>
      <p>No Screenings added yet.</p>
    <% } else { %>
      <%
        // Separate upcoming and played screenings
        const now = new Date();
        const upcoming = [];
        const played = [];
        
        screenings.forEach(screening => {
          const screeningDate = new Date(screening.date);
          const [endHours, endMins] = screening.endTime.split(':').map(Number);
          screeningDate.setHours(endHours, endMins, 0, 0);
          
          if (screeningDate > now) {
            upcoming.push(screening);
          } else {
            played.push(screening);
          }
        });
      %>
      <h3 class="little-title">Upcoming Screenings</h3>
      <% if (upcoming.length === 0) { %>
        <p style="color: #666;">No upcoming screenings.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Movie</th>
              <th>Hall</th>
              <th>Date</th>
              <th>Time</th>
              <th>End Time</th>
              <th>Current Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% upcoming.forEach(screening => { %>
            <%
              const now = new Date();
              const screeningDate = new Date(screening.date);
              const [startHours, startMins] = screening.screeningTime.split(':').map(Number);
              const [endHours, endMins] = screening.endTime.split(':').map(Number);
              
              screeningDate.setHours(startHours, startMins, 0, 0);
              const endDateTime = new Date(screeningDate);
              endDateTime.setHours(endHours, endMins, 0, 0);
              
              const isPlaying = now >= screeningDate && now <= endDateTime;
              const displayStatus = isPlaying ? 'Playing' : screening.status;
            %>
            <tr>
              <td><%= screening.movieTitle %></td>
              <td><%= screening.hallName %></td>
              <td><%= screening.date ? screening.date.split('T')[0] : '' %></td>
              <td><%= screening.screeningTime %></td>
              <td><%= screening.endTime %></td>
              <td><span style="<%= isPlaying ? 'color: red; font-weight: bold;' : '' %>"><%= displayStatus %></span></td>
              <td>
                <form method="GET" action="/admin/screening/screening-management/<%= screening._id %>/edit" style="display:inline">
                  <button class="btn btn-sm btn-edit">Edit</button>
                </form>
                <form method="POST" action="/admin/screening/screening-management/<%= screening._id %>/delete" style="display:inline"
                  onsubmit="return confirm('Delete this screening?')">
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
                <button class="btn btn-sm btn-viewhall" onclick="viewSeats(this)" data-screening-id="<%= screening._id %>" data-movie-title="<%= screening.movieTitle %>" data-hall-name="<%= screening.hallName %>" data-hall-id="<%= screening.hallId %>">View Seats</button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>

      <h3 class="little-title">Played Screenings</h3>
      <% if (played.length === 0) { %>
        <p style="color: #666;">No played screenings yet.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Movie</th>
              <th>Hall</th>
              <th>Date</th>
              <th>Time</th>
              <th>End Time</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% played.forEach(screening => { %>
            <tr style="background-color: #f5f5f5;">
              <td><%= screening.movieTitle %></td>
              <td><%= screening.hallName %></td>
              <td><%= screening.date ? screening.date.split('T')[0] : '' %></td>
              <td><%= screening.screeningTime %></td>
              <td><%= screening.endTime %></td>
              <td><span style="color: #999;">Played</span></td>
              <td>
                <form method="POST" action="/admin/screening/screening-management/<%= screening._id %>/delete" style="display:inline"
                  onsubmit="return confirm('Delete this screening?')">
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    <% } %>
  </div>

  <script src="/sidebar-toggle.js"></script>

  <!-- Seat Viewer Modal -->
  <div id="seatViewerModal" class="modal" style="display: none;">
    <div class="modal-content">
      <span class="close" onclick="closeSeatViewer()">&times;</span>
      <div style="padding: 20px;">
        <h2 id="seatViewerTitle"></h2>
        <div id="seatViewerContent">
          <p>Loading seating diagram...</p>
        </div>
      </div>
    </div>
  </div>
  <script>
    const searchInput = document.getElementById('screeningSearchInput');
    const upcomingRows = document.querySelectorAll('table tbody tr');

    searchInput.addEventListener('keyup', () => {
      const searchTerm = searchInput.value.toLowerCase();
      upcomingRows.forEach(row => {
        const movieCell = row.cells[0];
        const hallCell = row.cells[1];
        const movieTitle = movieCell ? movieCell.textContent.toLowerCase() : '';
        const hallName = hallCell ? hallCell.textContent.toLowerCase() : '';
        
        if (movieTitle.includes(searchTerm) || hallName.includes(searchTerm)) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });

    // Seat Viewer Functions
    let seatViewerRefreshInterval;

    async function viewSeats(button) {
      const screeningId = button.getAttribute('data-screening-id');
      const movieTitle = button.getAttribute('data-movie-title');
      const hallName = button.getAttribute('data-hall-name');
      const hallId = button.getAttribute('data-hall-id');

      document.getElementById('seatViewerTitle').textContent = `${movieTitle} - ${hallName}`;
      document.getElementById('seatViewerContent').innerHTML = '<p>Loading seating diagram...</p>';
      document.getElementById('seatViewerModal').style.display = 'flex';

      // Clear any existing refresh interval
      if (seatViewerRefreshInterval) clearInterval(seatViewerRefreshInterval);

      // Load seats immediately and then every 3 seconds
      await loadSeatsData(screeningId, hallId);
      seatViewerRefreshInterval = setInterval(() => loadSeatsData(screeningId, hallId), 3000);
    }

    function closeSeatViewer() {
      document.getElementById('seatViewerModal').style.display = 'none';
      if (seatViewerRefreshInterval) clearInterval(seatViewerRefreshInterval);
    }

    async function loadSeatsData(screeningId, hallId) {
      try {
        // Fetch hall details
        const hallRes = await fetch(`/api/halls/${hallId}`);
        const hall = await hallRes.json();

        // Fetch booked seats
        const bookingsRes = await fetch(`/api/bookings/screening/${screeningId}`);
        const bookingsData = await bookingsRes.json();
        const bookedSeats = bookingsData.bookedSeats || [];

        // Generate seats if not in hall.seat array
        let seats = hall.seat && hall.seat.length > 0 ? hall.seat : [];
        
        if (seats.length === 0 && hall.rows && hall.columns) {
          const generatedSeats = [];
          for (let r = 0; r < hall.rows; r++) {
            const rowLabel = String.fromCharCode(65 + r);
            for (let c = 1; c <= hall.columns; c++) {
              const wheelchairCount = hall.wheelchair || 0;
              const isWheelchair = (r === hall.rows - 1) && (c > hall.columns - wheelchairCount);
              generatedSeats.push({
                row: rowLabel,
                col: c,
                type: isWheelchair ? 'wheelchair' : 'normal'
              });
            }
          }
          seats = generatedSeats;
        }

        // Group seats by row
        const rows = {};
        seats.forEach((seat, index) => {
          if (!rows[seat.row]) rows[seat.row] = [];
          rows[seat.row].push({ ...seat, index });
        });

        // Render seating grid
        let html = '<div class="screen">SCREEN</div>';
        html += '<div class="seating-grid">';

        Object.keys(rows).sort().forEach(rowLetter => {
          html += '<div class="seat-row">';
          html += `<div class="row-label">${rowLetter}</div>`;

          rows[rowLetter].forEach(({ col, type, index }) => {
            const seatLabel = `${rowLetter}${col}`;
            const isBooked = bookedSeats.includes(seatLabel);
            const isDisabled = type === 'deleted';
            const isWheelchair = type === 'wheelchair';

            let seatClass = 'seat';
            if (isDisabled) seatClass += ' disabled';
            else if (isWheelchair) seatClass += ' wheelchair';
            else if (isBooked) seatClass += ' booked';

            const displayText = isWheelchair ? '♿' : isDisabled ? '✕' : col;
            const title = isDisabled ? 'Disabled' : isWheelchair ? 'Wheelchair accessible' : isBooked ? `Booked - ${seatLabel}` : seatLabel;

            html += `<button class="${seatClass}" title="${title}" disabled>${displayText}</button>`;
          });

          html += '</div>';
        });

        html += '</div>';

        // Add legend
        html += `
          <div class="seat-legend">
            <div class="legend-item">
              <div class="legend-seat available"></div>
              <span>Available</span>
            </div>
            <div class="legend-item">
              <div class="legend-seat booked"></div>
              <span>Booked</span>
            </div>
            <div class="legend-item">
              <div class="legend-seat wheelchair"></div>
              <span>Wheelchair</span>
            </div>
            <div class="legend-item">
              <div class="legend-seat disabled"></div>
              <span>Disabled</span>
            </div>
          </div>
        `;

        // Add booking stats
        const totalCapacity = seats.length;
        const availableSeats = totalCapacity - bookedSeats.length;
        const occupancyPercent = ((bookedSeats.length / totalCapacity) * 100).toFixed(1);

        html += `
          <div class="booking-stats">
            <p><strong>Total Capacity:</strong> ${totalCapacity} seats</p>
            <p><strong>Booked:</strong> ${bookedSeats.length} seats</p>
            <p><strong>Available:</strong> ${availableSeats} seats</p>
            <p><strong>Occupancy:</strong> ${occupancyPercent}%</p>
          </div>
        `;

        document.getElementById('seatViewerContent').innerHTML = html;
      } catch (error) {
        console.error('Error loading seats:', error);
        document.getElementById('seatViewerContent').innerHTML = `<p style="color: #f44336;">Error loading seating diagram: ${error.message}</p>`;
      }
    }

    // Close modal when clicking outside
    window.onclick = function(event) {
      const modal = document.getElementById('seatViewerModal');
      if (event.target === modal) {
        closeSeatViewer();
      }
    };
  </script>
</body>
</html>