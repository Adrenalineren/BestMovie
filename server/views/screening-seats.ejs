<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Screening Seats - CineVillage</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/index.css">
  <style>
    .screening-container {
      padding: 20px;
      background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
      min-height: 100vh;
    }

    .screening-header {
      margin-bottom: 30px;
    }

    .screening-title {
      color: #ffd700;
      font-size: 28px;
      margin: 0 0 10px 0;
    }

    .screening-info {
      color: #ccc;
      font-size: 16px;
      margin: 5px 0;
    }

    .screening-content {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid #ffd700;
      border-radius: 8px;
      padding: 30px;
    }

    .screen {
      text-align: center;
      color: #ffd700;
      font-size: 16px;
      font-weight: bold;
      margin-bottom: 40px;
      padding: 10px;
      border: 2px dashed #ffd700;
      border-radius: 4px;
    }

    .seating-grid {
      display: flex;
      flex-direction: column;
      gap: 15px;
      margin-bottom: 40px;
      padding: 20px;
      background: rgba(0, 0, 0, 0.2);
      border-radius: 8px;
      align-items: center;
    }

    .seat-row {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .row-label {
      width: 35px;
      text-align: center;
      color: #ffd700;
      font-weight: bold;
      font-size: 14px;
      flex-shrink: 0;
    }

    .seat {
      width: 40px;
      height: 40px;
      border: 2px solid #ccc;
      border-radius: 4px;
      background: #4a90e2;
      color: #fff;
      font-size: 11px;
      font-weight: bold;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .seat.available {
      background: #4a90e2;
      border-color: #4a90e2;
      cursor: pointer;
    }

    .seat.booked {
      background: #e74c3c;
      border-color: #ea1f1f;
      color: #666;
      cursor: not-allowed;
    }

    .seat.wheelchair {
      background: #9e7dd6;
      border-color: #c883d4;
      cursor: not-allowed;
    }

    .seat.disabled {
      background: #666;
      border-color: #999;
      cursor: not-allowed;
    }

    .legend {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
      padding: 20px;
      background: rgba(0, 0, 0, 0.2);
      border-radius: 8px;
      margin-bottom: 30px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #ccc;
    }

    .legend-seat {
      width: 25px;
      height: 25px;
      border: 1px solid #ccc;
      border-radius: 3px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .bookings-list {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid #ffd700;
      border-radius: 8px;
      padding: 20px;
      margin-top: 30px;
    }

    .bookings-title {
      color: #ffd700;
      font-size: 18px;
      margin: 0 0 20px 0;
      font-weight: bold;
    }

    .booking-item {
      background: rgba(0, 0, 0, 0.2);
      padding: 12px;
      margin-bottom: 10px;
      border-radius: 4px;
      border-left: 3px solid #ffd700;
    }

    .booking-customer {
      color: #ffd700;
      font-weight: bold;
    }

    .booking-seats {
      color: #ccc;
      font-size: 14px;
      margin-top: 5px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 15px;
      margin-top: 30px;
    }

    .stat-box {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid #ffd700;
      border-radius: 8px;
      padding: 15px;
      text-align: center;
    }

    .stat-label {
      color: #999;
      font-size: 12px;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .stat-value {
      color: #ffd700;
      font-size: 24px;
      font-weight: bold;
    }

    .loading {
      text-align: center;
      color: #ccc;
      padding: 40px;
    }

    .error {
      background: rgba(231, 76, 60, 0.1);
      border: 1px solid #e74c3c;
      border-radius: 8px;
      padding: 20px;
      color: #e74c3c;
      margin: 20px 0;
    }

    @media (max-width: 768px) {
      .screening-content {
        padding: 15px;
      }

      .seat {
        width: 30px;
        height: 30px;
        font-size: 9px;
      }

      .legend {
        gap: 10px;
      }

      .legend-item {
        font-size: 12px;
      }

      .legend-seat {
        width: 20px;
        height: 20px;
      }
    }
  </style>
</head>
<body>
  <%- include('navbar') %>
  <%- include('sidebar') %>

  <div class="screening-container">
    <div class="dashboard">
      <div class="container-dashboard">
        <div class="screening-header">
          <h1 class="screening-title" id="movieTitle">Loading...</h1>
          <div class="screening-info" id="screeningInfo">-</div>
          <div class="screening-info" id="hallInfo">-</div>
        </div>

        <div id="errorMessage" class="error" style="display: none;"></div>

        <div id="content" style="display: none;">
          <div class="screening-content">
            <div class="screen">🎬 SCREEN</div>
            <div class="seating-grid" id="seatingGrid">-</div>
          </div>

          <div class="legend">
            <div class="legend-item">
              <div class="legend-seat" style="background: #4a90e2; border-color: #4a90e2;"></div>
              <span>Available</span>
            </div>
            <div class="legend-item">
              <div class="legend-seat" style="background: #e74c3c; border-color: #ea1f1f;"></div>
              <span>Booked</span>
            </div>
            <div class="legend-item">
              <div class="legend-seat" style="background: #9e7dd6; border-color: #c883d4;"></div>
              <span>Wheelchair</span>
            </div>
            <div class="legend-item">
              <div class="legend-seat" style="background: #666; border-color: #999;"></div>
              <span>Disabled</span>
            </div>
          </div>

          <div class="stats-grid">
            <div class="stat-box">
              <div class="stat-label">Total Seats</div>
              <div class="stat-value" id="totalSeats">-</div>
            </div>
            <div class="stat-box">
              <div class="stat-label">Booked Seats</div>
              <div class="stat-value" id="bookedSeatsCount">-</div>
            </div>
            <div class="stat-box">
              <div class="stat-label">Available Seats</div>
              <div class="stat-value" id="availableSeatsCount">-</div>
            </div>
            <div class="stat-box">
              <div class="stat-label">Occupancy Rate</div>
              <div class="stat-value" id="occupancyRate">-</div>
            </div>
          </div>

          <div class="bookings-list" id="bookingsList">
            <h3 class="bookings-title">Booking Details</h3>
            <div id="bookingsContent">Loading...</div>
          </div>
        </div>

        <div id="loading" class="loading">
          <i class="bi bi-hourglass-split" style="font-size: 40px; margin-bottom: 10px; display: block;"></i>
          <p>Loading screening details...</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    const screeningId = '<%= screeningId %>';

    async function loadScreeningData() {
      try {
        const response = await fetch(`/api/admin/screening/${screeningId}/seats`);
        
        if (!response.ok) {
          throw new Error('Screening not found');
        }

        const data = await response.json();

        if (!data.success) {
          throw new Error(data.error || 'Failed to load screening data');
        }

        // Update screening info
        const screening = data.screening;
        document.getElementById('movieTitle').textContent = screening.movieTitle;
        document.getElementById('screeningInfo').textContent = `📅 ${screening.date} @ ${screening.screeningTime}`;
        document.getElementById('hallInfo').textContent = `🎪 ${data.hall.name}`;

        // Update stats
        const stats = data.bookingStats;
        document.getElementById('totalSeats').textContent = stats.totalCapacity;
        document.getElementById('bookedSeatsCount').textContent = stats.totalBooked;
        document.getElementById('availableSeatsCount').textContent = stats.totalCapacity - stats.totalBooked;
        document.getElementById('occupancyRate').textContent = stats.percentBooked + '%';

        // Render seating grid
        const seatConfig = data.hall.seatConfiguration;
        const seatingHtml = Object.keys(seatConfig).sort().map(rowLetter => {
          const seats = seatConfig[rowLetter];
          const seatsHtml = seats.map(seat => {
            let seatClass = 'seat';
            let content = seat.col;

            if (seat.type === 'disabled') {
              seatClass += ' disabled';
              content = '✕';
            } else if (seat.type === 'wheelchair') {
              seatClass += ' wheelchair';
              content = '♿';
            } else if (seat.isBooked) {
              seatClass += ' booked';
            } else {
              seatClass += ' available';
            }

            return `<div class="${seatClass}" title="${seat.label}">${content}</div>`;
          }).join('');

          return `
            <div class="seat-row">
              <div class="row-label">${rowLetter}</div>
              ${seatsHtml}
            </div>
          `;
        }).join('');

        document.getElementById('seatingGrid').innerHTML = seatingHtml;

        // Render bookings list
        const bookings = data.bookings;
        if (bookings.length === 0) {
          document.getElementById('bookingsContent').innerHTML = '<p style="color: #999;">No bookings for this screening</p>';
        } else {
          const bookingsHtml = bookings.map(booking => `
            <div class="booking-item">
              <div class="booking-customer">${booking.customerName}</div>
              <div class="booking-seats">Seats: ${booking.seats}</div>
              <div class="booking-seats">Amount: <strong>S$${booking.totalAmount.toFixed(2)}</strong></div>
            </div>
          `).join('');
          document.getElementById('bookingsContent').innerHTML = bookingsHtml;
        }

        // Show content
        document.getElementById('loading').style.display = 'none';
        document.getElementById('content').style.display = 'block';

      } catch (error) {
        console.error('Error:', error);
        document.getElementById('loading').style.display = 'none';
        document.getElementById('errorMessage').style.display = 'block';
        document.getElementById('errorMessage').innerHTML = `
          <i class="bi bi-exclamation-triangle"></i>
          <strong>Error:</strong> ${error.message}
        `;
      }
    }

    // Auto-refresh every 10 seconds
    window.setInterval(loadScreeningData, 10000);

    // Initial load
    loadScreeningData();
  </script>
</body>
</html>
